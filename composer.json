{
    "name": "arsy/sso-client",
    "description": "Cliente unificado de Single Sign-On (SSO) para aplicaciones del ecosistema Arsy.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1|^8.2|^8.3",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "laravel/socialite": "^5.0",
        "socialiteproviders/laravelpassport": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Arsy\\SSOClient\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Arsy\\SSOClient\\Providers\\SsoClientServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
